        </mxCell>
        <mxCell id="i_h3" value="&lt;font style=&quot;font-size:9px&quot;&gt;Recall: before LLM sees message&lt;br&gt;Stop: after LLM responds&lt;br&gt;Zero LLM initiative needed&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999;fontSize=9;fontStyle=2;" vertex="1" parent="1">
