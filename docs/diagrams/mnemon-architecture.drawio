        </mxCell>
        <mxCell id="i_c2" value="&lt;b&gt;Remember Trigger&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;After each response, ask:&lt;br&gt;&quot;If I forget this, does the&lt;br&gt;user have to repeat?&quot;&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E6FFE6;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
