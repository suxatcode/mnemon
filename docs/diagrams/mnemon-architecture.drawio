        <mxCell id="i_c1" value="&lt;b&gt;Recall Guidance&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;When [Past memory] appears:&lt;br&gt;reference relevant memories&lt;br&gt;rather than re-deriving&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E6FFE6;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
