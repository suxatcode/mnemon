        <mxCell id="i_claude_title" value="&lt;b&gt;Layer 2: CLAUDE.md (Behavioral Guidance)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Project-level instructions with high authority&lt;/font&gt;" style="text;html=1;align=left;fontSize=12;fillColor=none;strokeColor=none;" vertex="1" parent="1">
