        </mxCell>
        <mxCell id="i_c3" value="&lt;b&gt;Three Worth-Remembering Types&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;1. User directives&lt;br&gt;2. Reasoning conclusions&lt;br&gt;3. Observed state&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E6FFE6;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
