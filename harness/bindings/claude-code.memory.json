{
  "schema_version": 1,
  "name": "claude-code.memory",
  "host": "claude-code",
  "loop": "memory",
  "projection_path": ".claude",
  "runtime_surface": ".claude/mnemon-memory",
  "lifecycle_mapping": {
    "prime": "SessionStart",
    "remind": "UserPromptSubmit",
    "nudge": "Stop",
    "compact": "PreCompact"
  },
  "runner_bindings": {
    "memory.dreaming": {
      "mode": "native_subagent",
      "agent": "mnemon-dreaming",
      "fallback_runner": "codex-app-server"
    }
  },
  "reconcile": ["read", "write", "compact", "consolidate", "no-op"]
}
