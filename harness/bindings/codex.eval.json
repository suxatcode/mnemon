{
  "schema_version": 1,
  "name": "codex.eval",
  "host": "codex",
  "loop": "eval",
  "projection_path": ".codex",
  "runtime_surface": ".codex/mnemon-eval",
  "lifecycle_mapping": {
    "prime": "SessionStart",
    "remind": "UserPromptSubmit",
    "nudge": "Stop",
    "compact": "PreCompact",
    "maintenance": "app-server eval"
  },
  "runner_bindings": {
    "eval.evaluator": {
      "mode": "app_server",
      "runner": "codex-app-server",
      "prompt_from": "subagents/evaluator.md"
    }
  },
  "reconcile": ["plan", "run", "analyze", "improve", "retire", "no-op"]
}
