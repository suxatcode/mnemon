{
  "schema_version": 2,
  "name": "skill",
  "version": "0.1.0",
  "description": "Manages active, stale, and archived skills through evidence, curator review, and approved lifecycle changes.",
  "surfaces": {
    "projection": [
      "active skills",
      "skill-observe",
      "skill-curate",
      "skill-author",
      "skill-manage",
      "curator",
      "runtime env"
    ],
    "observation": [
      "usage sidecar",
      "signal reports",
      "curator reports",
      "host skill drift",
      "review decisions"
    ]
  },
  "assets": {
    "guide": "GUIDE.md",
    "env": "env.sh",
    "skills": [
      "skills/skill-observe/SKILL.md",
      "skills/skill-curate/SKILL.md",
      "skills/skill-author/SKILL.md",
      "skills/skill-manage/SKILL.md"
    ],
    "subagents": [
      "subagents/curator.md"
    ]
  },
  "host_adapters": {
    "claude-code": "../../hosts/claude-code",
    "codex": "../../hosts/codex"
  }
}
