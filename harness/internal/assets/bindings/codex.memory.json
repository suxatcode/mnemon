{
  "schema_version": 1,
  "name": "codex.memory",
  "host": "codex",
  "loop": "memory",
  "projection_path": ".codex",
  "runtime_surface": ".codex/mnemon-memory",
  "lifecycle_mapping": {
    "prime": "SessionStart",
    "remind": "UserPromptSubmit",
    "nudge": "Stop",
    "compact": "PreCompact"
  },
  "runner_bindings": {
    "memory.dreaming": {
      "mode": "app_server",
      "runner": "codex-app-server",
      "prompt_from": "subagents/dreaming.md"
    }
  },
  "reconcile": ["read", "write", "compact", "consolidate", "no-op"]
}
